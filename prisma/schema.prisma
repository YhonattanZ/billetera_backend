datasource db {
  provider = "mysql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model Usuario {
  id               Int            @id @default(autoincrement())
  nombre           String
  email            String         @unique
  password         String
  creadoEn         DateTime       @default(now()) @map("creado_en")
  cuenta           Cuenta?

  @@map("usuarios")
}

model Cuenta {
  id                  Int            @id @default(autoincrement())
  numeroCuenta        String         @unique @map("numero_cuenta")
  saldo               Decimal        @db.Decimal(15, 2) @default(0.00)
  usuarioId           Int            @unique @map("usuario_id")
  usuario             Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  transaccionesEnvia  Transaccion[]  @relation("Envios")
  transaccionesRecibe Transaccion[]  @relation("Recepciones")

  @@map("cuentas")
}

model Transaccion {
  id              Int      @id @default(autoincrement())
  cuentaOrigenId  Int      @map("cuenta_origen_id")
  cuentaDestinoId Int      @map("cuenta_destino_id")
  monto           Decimal  @db.Decimal(15, 2)
  glosa           String
  creadoEn        DateTime @default(now()) @map("creado_en")

  cuentaOrigen  Cuenta @relation("Envios", fields: [cuentaOrigenId], references: [id])
  cuentaDestino Cuenta @relation("Recepciones", fields: [cuentaDestinoId], references: [id])

  @@map("transacciones")
}